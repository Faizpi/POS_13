{
    "_meta": {
        "source": "Captured from legacy Laravel 7 controller code analysis",
        "date": "2026-06-05",
        "controller": "App\\Http\\Controllers\\Api\\AuthController"
    },
    "login": {
        "endpoint": "POST /api/v1/login",
        "middleware": "none (public)",
        "validation": {
            "email": "required|email",
            "password": "required|string",
            "device_name": "nullable|string|max:255"
        },
        "success": {
            "status": 200,
            "body": {
                "message": "Login berhasil.",
                "token": "<string:64-char-random>",
                "user": {
                    "id": "<int>",
                    "name": "<string>",
                    "email": "<email>",
                    "role": "<enum:super_admin|admin|spectator|user>",
                    "alamat": "<string|null>",
                    "no_telp": "<string|null>",
                    "avatar_url": "<url|null>",
                    "gudang_id": "<int|null>",
                    "current_gudang_id": "<int|null>"
                }
            }
        },
        "failure_invalid_credentials": {
            "status": 401,
            "body": {
                "message": "Email atau password salah."
            }
        },
        "failure_validation": {
            "status": 422,
            "body": "Laravel standard validation JSON"
        }
    },
    "logout": {
        "endpoint": "POST /api/v1/logout",
        "middleware": "api.token",
        "validation": "none",
        "success": {
            "status": 200,
            "body": {
                "message": "Logout berhasil."
            }
        },
        "side_effects": "Deletes PersonalAccessToken row by api_token_id"
    },
    "profile": {
        "endpoint": "GET /api/v1/profile",
        "middleware": "api.token",
        "validation": "none",
        "success": {
            "status": 200,
            "body": {
                "user": {
                    "id": "<int>",
                    "name": "<string>",
                    "email": "<email>",
                    "role": "<enum>",
                    "alamat": "<string|null>",
                    "no_telp": "<string|null>",
                    "avatar_url": "<url|null>",
                    "gudang_id": "<int|null>",
                    "current_gudang_id": "<int|null>"
                },
                "gudang": {
                    "id": "<int>",
                    "nama_gudang": "<string>",
                    "alamat_gudang": "<string|null>"
                }
            }
        },
        "notes": "gudang is null if user has no current gudang"
    },
    "update_profile": {
        "endpoint": "PUT /api/v1/profile",
        "middleware": "api.token",
        "validation": {
            "name": "sometimes|string|max:255",
            "alamat": "nullable|string",
            "no_telp": "nullable|string|max:20"
        },
        "success": {
            "status": 200,
            "body": {
                "message": "Profil berhasil diupdate.",
                "user": "<same user shape as login>"
            }
        }
    },
    "change_password": {
        "endpoint": "POST /api/v1/change-password",
        "middleware": "api.token",
        "validation": {
            "current_password": "required|string",
            "new_password": "required|string|min:8|confirmed"
        },
        "success": {
            "status": 200,
            "body": {
                "message": "Password berhasil diubah."
            }
        },
        "failure_wrong_password": {
            "status": 422,
            "body": {
                "message": "Password lama salah."
            }
        }
    },
    "upload_avatar": {
        "endpoint": "POST /api/v1/profile/avatar",
        "middleware": "api.token",
        "validation_file_mode": {
            "avatar": "required|image|mimes:jpeg,jpg,png,webp|max:5120"
        },
        "validation_base64_mode": "avatar_base64 field (manual decode)",
        "success": {
            "status": 200,
            "body": {
                "message": "Avatar berhasil diupload.",
                "avatar_url": "<url>",
                "user": "<same user shape>"
            }
        },
        "failure_invalid_base64": {
            "status": 422,
            "body": {
                "message": "Data gambar tidak valid."
            }
        },
        "failure_no_file": {
            "status": 422,
            "body": {
                "message": "Tidak ada file avatar yang dikirim."
            }
        },
        "side_effects": "Compresses to max 400x400 JPEG quality 82. Stores in storage/avatars/{user_id}_{timestamp}.jpg"
    },
    "delete_avatar": {
        "endpoint": "DELETE /api/v1/profile/avatar",
        "middleware": "api.token",
        "validation": "none",
        "success": {
            "status": 200,
            "body": {
                "message": "Avatar berhasil dihapus.",
                "user": "<same user shape with avatar_url null>"
            }
        },
        "side_effects": "Deletes physical file, sets avatar column null"
    }
}